	(title_block
		(title "Dual Channel CW Laser + TEC Driver — ML20550KK14Z600L")
		(date "2025-05-22")
		(rev "3.0")
		(company "Lab R&D")
		(comment 1 "1550nm 70mW DFB butterfly | Bipolar TEC H-bridge -1.5A/+2.5A | AD5064 16-bit DAC")
		(comment 2 "Rail2: LM7807->LT3042->LTC6655-5 | Rail3: LM7805->RC->LT3045 | Rail4/5: ±LM780x->LT3045/94")
		(comment 3 "Readback: INA826 laser+TEC current, NTC thermistor divider, OPA380 MPD TIA")
	)
	(lib_symbols)
	(text "Need 300 mA +15 V\nNeed 150 mA -15 V\nNeed 5 V 600 mA for laser"
		(exclude_from_sim no)
		(at 33.782 20.828 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "4b0a0f47-200c-43ce-bd3a-46b9d54d0e3e")
	)
	(text "KEY DESIGN PARAMETERS (v3.0):\nLaser: ML20550KK14Z600L 1550nm 70mW DFB butterfly\n  Iop=500mA typ, 600mA max, Vf=2V, Vr_max=2V\n  Sense: R5=0.25R, INA826 G=12 (Rg=4.53k), Vout_max=3.0V @ 600mA\nTEC bipolar H-bridge: -1.5A to +2.5A, ±3.8V max\n  Virtual zero: TEC_VZERO=1.875V (R19=12.7k/R20=9.31k from 5V_DAC)\n  DAC code 24576 = 0A TEC | 0 = +2.5A cool | 65535 = -1.5A heat\n  Sense: R7=0.1R, INA826 G=20 (Rg=2.61k), Vout_max=3.0V @ 2.5A\n  H-bridge: Q3/Q5=IRF9540N P-ch, Q4/Q6=IRLB8721 N-ch, TO-220 offboard\n  Control supply: +6V/-6V from LT3045/LT3094 (0.8uV rms each)\n  H-bridge power: +8V/-8V directly from LM7808/LM7908\nNTC: 10k @ 25C, beta=3950K, divider 10k->3V3, spans 1.18-2.06V\nMPD TIA: OPA380, Rf=10k, Cf=2.2pF, Vout=Ipd*10k (3V @ 300uA)\nButterfly pinout confirmed: P1=TEC+ P2=NTC_A P5=NTC_GND\n  P10=CHIP+ P11=CHIP- P13=GND P14=TEC- | P3/4/6/7/8/9/12=NC pend YBP"
		(exclude_from_sim no)
		(at 201.676 145.034 0)
		(effects
			(font
				(size 1 1)
			)
			(justify left)
		)
		(uuid "cbf3cc56-e3ed-49b6-96a3-c4622727d6bd")
	)
